{
    "name": "ekumanov/flarum-ext-inline-audio",
    "description": "Automatically converts audio file links into inline players in posts, with optional [player] BBCode tag",
    "keywords": [
        "flarum",
        "extension",
        "audio",
        "player",
        "inline"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "require": {
        "flarum/core": "^1.8.0"
    },
    "authors": [
        {
            "name": "ekumanov",
            "email": "ekumanov@users.noreply.github.com"
        }
    ],
    "extra": {
        "flarum-extension": {
            "title": "Inline Audio Player",
            "icon": {
                "name": "fas fa-music",
                "backgroundColor": "#2980b9",
                "color": "#fff"
            }
        }
    }
}
